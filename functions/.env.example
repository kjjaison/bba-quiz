# Copy to .env and fill in before deploying Cloud Functions (Blaze plan required).

# Legacy API proxy — still used for login/submit until fully migrated
APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# Google Sheet ID (from the sheet URL: .../d/THIS_PART/edit)
SPREADSHEET_ID=your_google_sheet_id_here

# Shared secret for Sheet → Firestore sync (match SYNC_SECRET in gas/Config.gs Settings sheet)
SYNC_SECRET=choose-a-long-random-string
