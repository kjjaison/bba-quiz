{
  "hosting": {
    "public": "web-frontend",
    "ignore": [
      "firebase.json",
      "firebase.spark.json",
      "**/.*",
      "**/node_modules/**",
      "README.md",
      "config.example.js"
    ],
    "headers": [
      {
        "source": "/index.html",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
        ]
      },
      {
        "source": "**/*.@(js|css)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
